services:
  wg-easy:
    image: ghcr.io/wg-easy/wg-easy:15
    container_name: wg-easy
    environment:
      - LANG=en
      # INIT_* は wg-easy-data が空の初回起動でのみ効く (以後の変更は UI 経由)。
      - INIT_ENABLED=true
      - INIT_USERNAME=admin
      # '$' は compose 変数展開で食われるので $$ にエスケープ。
      - INIT_PASSWORD={{ wg_password | replace('$', '$$') }}
      - INIT_HOST={{ wg_public_hostname }}
      - INIT_PORT={{ wg_port }}
      - INIT_DNS=1.1.1.1, 2606:4700:4700::1111
      # クライアント ULA は Docker bridge の /64 (fdcc:ad94:bacf:61a3::/64) と重ねないこと。
      - INIT_IPV4_CIDR=10.8.0.0/24
      - INIT_IPV6_CIDR=fdcc:ad94:bacf:61a4::/64
      - INIT_ALLOWED_IPS=0.0.0.0/0, ::/0
      - PORT=51821
      # TLS 終端は cloudflared 側、コンテナは平文 HTTP を許す。
      - INSECURE=true
    volumes:
      - ./wg-easy-data:/etc/wireguard
      # upstream の /lib/modules bind と SYS_MODULE は unprivileged LXC で no-op
      # (CT 内 modprobe 不可)。host 側で wireguard module ロード済み前提に倒す。
    ports:
      # 管理 UI(51821) は Tunnel 経由のみ。host へは publish しない。
      - "{{ wg_port }}:{{ wg_port }}/udp"
    cap_add:
      - NET_ADMIN
    sysctls:
      - net.ipv4.ip_forward=1
      - net.ipv4.conf.all.src_valid_mark=1
      - net.ipv6.conf.all.disable_ipv6=0
      - net.ipv6.conf.all.forwarding=1
      - net.ipv6.conf.default.forwarding=1
    healthcheck:
      # process running ≠ WG IF up。IF 名のハードコード回避で interfaces を見る。
      test: ["CMD-SHELL", "test -n \"$(wg show interfaces)\""]
      interval: 30s
      timeout: 5s
      retries: 3
      # cold start (image pull + INIT_* DB seed + WG IF up) で 30s では足りないことがある。
      start_period: 90s
    restart: unless-stopped
    networks:
      wg:
        ipv4_address: 10.42.42.42
        ipv6_address: fdcc:ad94:bacf:61a3::2a

  cloudflared:
    # :latest は使わない (unattended pull の binary 置換を避ける)。
    # 更新は https://github.com/cloudflare/cloudflared/releases を見て手動で。
    image: cloudflare/cloudflared:2026.5.1
    container_name: cloudflared
    # remotely-managed: ingress はダッシュボード側、ローカル config.yml / credentials JSON 無し。
    command: tunnel --no-autoupdate run
    environment:
      - TUNNEL_TOKEN={{ cf_tunnel_token }}
    restart: unless-stopped
    depends_on:
      - wg-easy
    networks:
      - wg

networks:
  wg:
    driver: bridge
    enable_ipv6: true
    ipam:
      driver: default
      config:
        - subnet: 10.42.42.0/24
        - subnet: fdcc:ad94:bacf:61a3::/64
