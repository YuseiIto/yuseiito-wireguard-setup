#!/bin/bash
set -euo pipefail

# Token は world-executable な本文に残さないため /etc/cf-ddns.env (0600) から読む。
# shellcheck source=/dev/null
. /etc/cf-ddns.env

ZONE_ID="{{ cf_zone_id }}"
RECORD_ID_V4="{{ cf_record_id }}"
RECORD_ID_V6="{{ cf_record_id_v6 }}"
RECORD_NAME="{{ wg_public_hostname }}"
HEALTHCHECK_URL="{{ cf_ddns_healthcheck_url | default('') }}"

# v4/v6 は片方失敗でもう片方を続行する。ただし v4 fetch (ipify -4) の単発失敗だけは
# errored を立てない — 一時障害で timer を赤に染めると本物の v6 故障を見落とすため。
errored=0

validate_v4() {
  local ip=$1
  [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
  local IFS=.
  local -a octets
  read -ra octets <<<"$ip"
  for o in "${octets[@]}"; do
    if (( o > 255 )); then return 1; fi
  done
  return 0
}

validate_v6() {
  # loose check — 厳密 v6 パースはやらない (v6 失敗は Happy Eyeballs で v4 fallback)。
  local ip=$1
  [[ "$ip" == *:* && "$ip" =~ ^[0-9a-fA-F:]+$ ]]
}

update_record() {
  local record_id=$1 record_type=$2 ip=$3
  local resp
  # -f は付けない: 4xx/5xx のボディに含まれる Cloudflare errors[] (token 失効 /
  # zone・record id ずれの切り分けに必要) を捨てたくないため。
  if ! resp=$(curl -sS --max-time 10 -X PUT \
      "https://api.cloudflare.com/client/v4/zones/${ZONE_ID}/dns_records/${record_id}" \
      -H "Authorization: Bearer ${CF_DDNS_TOKEN}" \
      -H "Content-Type: application/json" \
      --data "{\"type\":\"${record_type}\",\"name\":\"${RECORD_NAME}\",\"content\":\"${ip}\",\"ttl\":120,\"proxied\":false}"); then
    echo "cf-ddns: ${record_type} PUT failed: ${resp:-<no body>}" >&2
    return 1
  fi
  # jq の stderr は捨てない: 非 JSON ボディ (HTML interstitial / captive portal) の parse error
  # 自体が診断シグナル。$resp に token は乗らないので journal 漏洩リスクは無い。
  if ! jq -e '.success == true' >/dev/null <<<"$resp"; then
    echo "cf-ddns: ${record_type} update rejected: $resp" >&2
    return 1
  fi
}

# IPv4 path (best-effort on MAP-E)
ipv4=""
if ! ipv4=$(curl -fsS -4 --max-time 10 https://api.ipify.org); then
  echo "cf-ddns: failed to fetch IPv4 from ipify (best-effort, not erroring)" >&2
elif ! validate_v4 "$ipv4"; then
  echo "cf-ddns: invalid IPv4 from ipify: '$ipv4'" >&2
  errored=1
elif ! update_record "$RECORD_ID_V4" A "$ipv4"; then
  errored=1
fi

# IPv6 path
ipv6=""
if ! ipv6=$(curl -fsS -6 --max-time 10 https://api6.ipify.org); then
  echo "cf-ddns: failed to fetch IPv6 from ipify" >&2
  errored=1
elif ! validate_v6 "$ipv6"; then
  echo "cf-ddns: invalid IPv6 from ipify: '$ipv6'" >&2
  errored=1
elif ! update_record "$RECORD_ID_V6" AAAA "$ipv6"; then
  errored=1
fi

# `|| true` で ping 自身の失敗が timer を赤くするのを防ぐ。Jinja でなく runtime ガード
# にしてあるのは、レンダ後の bash が常に同じ形になり shellcheck を素通しできるよう。
if [[ -n "$HEALTHCHECK_URL" ]]; then
  curl -fsS --retry 3 --max-time 10 -o /dev/null \
    "${HEALTHCHECK_URL}/${errored}" || true
fi

exit "$errored"
